# Rezeror environment template
# Copy this file to .env and set values for your environment.

# Base directory for generated data (chapters, state JSON)
# Default in code: ./data (project root)
REZEROR_DATA_DIR=./data

# SQLite path for reading progress data
# Default in code: <REZEROR_DATA_DIR>/progress.sqlite3
REZEROR_DB_PATH=./data/progress.sqlite3

# Owner authentication for write-protected actions (progress updates and sync API)
# Auth is enabled only when REZEROR_OWNER_PASSWORD is non-empty.
REZEROR_OWNER_USERNAME=owner
REZEROR_OWNER_PASSWORD=change-me

# Flask session signing secret (required in production)
REZEROR_SESSION_SECRET=change-this-to-a-long-random-secret

# Owner login session duration in days (default: 3650 = ~10 years)
REZEROR_OWNER_SESSION_DAYS=3650
